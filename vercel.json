{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/server", "dest": "/api/server.js" },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/service-worker.js",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/index\\.html",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    }
  ]
}
